# =============================================================================
# Cerebray - Environment Variables
# Copy to backend/.env and fill in real values. Never commit .env.
# =============================================================================

# --- Server ---
PORT=8080
ENV=development
SESSION_SECRET=change-me-to-a-long-random-secret

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://cerebray:cerebray@localhost:5432/cerebray?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (Keycloak OIDC) ---
# Leave KEYCLOAK_ISSUER_URL empty for local auth mode (auto-creates admin user).
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=cerebray
KEYCLOAK_CLIENT_SECRET=
# Local auth mode (active when KEYCLOAK_ISSUER_URL is empty):
LOCAL_USER_EMAIL=admin@localhost
LOCAL_USER_NAME=Local Admin

# --- AI ---
AI_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-4-sonnet-20250514
AI_MONTHLY_TOKEN_BUDGET=2000000

# --- App URL ---
BASE_URL=http://localhost:5173

# --- Vault (used by task secrets:vault) ---
VAULT_TOKEN=hvs.your-vault-token-here

# --- Analytics (PostHog, optional) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
