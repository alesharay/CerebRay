# =============================================================================
# Deployment Configuration Overrides
#
# Copy to deploy.env and set values for your environment.
# These override the defaults in Taskfile.yml (which target the homelab).
# deploy.env is gitignored.
# =============================================================================

# Docker registry where backend and frontend images are pushed.
# REGISTRY=ghcr.io/your-org

# Public domain for the app (used in k8s ingress and backend BASE_URL).
# APP_DOMAIN=cerebray.example.com

# cert-manager ClusterIssuer name for TLS on the ingress.
# CERT_ISSUER=letsencrypt-prod

# ExternalSecrets ClusterSecretStore name (if using Vault + ESO).
# VAULT_SECRET_STORE=your-vault-store

# Vault KV path where cerebray secrets are stored.
# VAULT_PATH=secret/cerebray

# Path to the gitops repo where k8s manifests are written.
# GITOPS_DIR=../your-gitops-repo

# SSH connection details for the machine running Vault.
# NAS_HOST=your-server-ip
# NAS_USER=your-user
# NAS_SSH_KEY=~/.ssh/id_rsa
